{
  "name": "react-app",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/donniean/react-app#readme",
  "bugs": {
    "url": "https://github.com/donniean/react-app/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donniean/react-app.git"
  },
  "license": "MIT",
  "author": "Donnie An",
  "type": "module",
  "scripts": {
    "build": "pnpm run i18n:types && tsc --build && vite build",
    "dev": "vite",
    "docker:build": "docker buildx build --tag donniean/react-app --push .",
    "docker:build:multi": "docker buildx build --platform linux/amd64,linux/arm64 --tag donniean/react-app --push .",
    "docker:run": "docker run --publish=3000:80 -it --rm donniean/react-app",
    "format:package-json": "sort-package-json \"**/package.json\" --ignore \"**/node_modules/**/package.json\" --ignore \"**/dist/**/package.json\"",
    "format:package-json:check": "pnpm run format:package-json --check",
    "format:prettier": "prettier --write --ignore-unknown .",
    "format:prettier:check": "prettier --check --ignore-unknown .",
    "i18n:extract": "i18next-cli extract",
    "i18n:lint": "i18next-cli lint",
    "i18n:status": "i18next-cli status",
    "i18n:sync": "i18next-cli sync",
    "i18n:types": "i18next-cli types && prettier --write src/@types/i18next-resources.d.ts",
    "lint": "concurrently --group --timings \"pnpm:lint:*(!:fix|^lint:knip$)\" \"pnpm:format:*:check\" \"pnpm:typecheck\"",
    "lint:autocorrect": "autocorrect --lint",
    "lint:autocorrect:fix": "autocorrect --fix",
    "lint:eslint": "eslint",
    "lint:eslint:fix": "eslint --fix",
    "lint:fix": "concurrently --max-processes=1 --group --timings \"pnpm:lint:*:fix(!^lint:knip:fix$)\" \"pnpm:format:*(!:check)\"",
    "lint:html": "html-validate \"**/*.html\"",
    "lint:i18n": "pnpm run i18n:status && pnpm run i18n:extract --ci --dry-run && pnpm run i18n:lint",
    "lint:knip": "knip",
    "lint:knip:fix": "knip --fix",
    "lint:markdown": "markdownlint --dot \"**/*.md\"",
    "lint:markdown:fix": "pnpm run lint:markdown --fix",
    "lint:spellcheck": "cspell lint --no-progress --no-must-find-files --dot --gitignore .",
    "lint:styles": "stylelint \"**/*.css\"",
    "lint:styles:fix": "pnpm run lint:styles --fix",
    "ncu": "ncu --deep --format cooldown",
    "ncu:upgrade": "pnpm run ncu --upgrade",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --pass-with-no-tests",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "typecheck": "tsc --build --clean && tsc --build"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "clsx": "2.1.1",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.8",
    "react-router": "7.17.0",
    "remeda": "2.39.0",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@commitlint/types": "21.0.1",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/compat": "2.1.0",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@types/babel__core": "7.20.5",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/eslint-plugin": "1.6.20",
    "@vitest/ui": "4.1.9",
    "autocorrect-node": "2.14.0",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-i18next": "6.1.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-sonarjs": "4.0.3",
    "eslint-plugin-unicorn": "65.0.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "html-validate": "11.5.3",
    "husky": "9.1.7",
    "i18next-cli": "1.64.0",
    "knip": "6.16.1",
    "lint-staged": "17.0.7",
    "markdownlint-cli": "0.48.0",
    "npm-check-updates": "22.2.3",
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sort-package-json": "4.0.0",
    "stylelint": "17.13.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.0.16",
    "vite-plugin-checker": "0.14.1",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.8"
  },
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  }
}
