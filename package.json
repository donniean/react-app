{
  "name": "react-app",
  "version": "0.0.0",
  "private": true,
  "homepage": "https://github.com/donniean/react-app#readme",
  "bugs": {
    "url": "https://github.com/donniean/react-app/issues"
  },
  "license": "MIT",
  "author": "Donnie An",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/donniean/react-app.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm run i18n:types && tsc --build && vite build",
    "dev": "vite",
    "docker:build": "docker buildx build --tag donniean/react-app --push .",
    "docker:build:multi": "docker buildx build --platform linux/amd64,linux/arm64 --tag donniean/react-app --push .",
    "docker:run": "docker run --publish=3000:80 --rm donniean/react-app",
    "format:oxfmt": "oxfmt",
    "format:oxfmt:check": "oxfmt --check",
    "i18n:extract": "i18next-cli extract",
    "i18n:lint": "i18next-cli lint",
    "i18n:status": "i18next-cli status",
    "i18n:sync": "i18next-cli sync",
    "i18n:types": "i18next-cli types && oxfmt src/@types/i18next-resources.d.ts",
    "lint": "concurrently --group --timings \"pnpm:format:*:check\" \"pnpm:lint:*(!:fix)\" \"pnpm:typecheck\"",
    "lint:autocorrect": "autocorrect --lint",
    "lint:autocorrect:fix": "autocorrect --fix",
    "lint:fix": "concurrently --max-processes=1 --group --timings \"pnpm:lint:*:fix\" \"pnpm:format:*(!:check)\"",
    "lint:html": "html-validate .",
    "lint:i18n": "pnpm run i18n:status && pnpm run i18n:extract --ci --dry-run && pnpm run i18n:lint",
    "lint:knip": "knip",
    "lint:knip:fix": "knip --fix",
    "lint:markdown": "markdownlint --dot .",
    "lint:markdown:fix": "pnpm run lint:markdown --fix",
    "lint:oxlint": "oxlint",
    "lint:oxlint:fix": "oxlint --fix",
    "lint:spellcheck": "cspell --no-progress --dot --gitignore .",
    "lint:styles": "stylelint \"**/*.css\"",
    "lint:styles:fix": "pnpm run lint:styles --fix",
    "ncu": "ncu --deep --format cooldown",
    "ncu:upgrade": "pnpm run ncu --upgrade",
    "prepare": "husky",
    "preview": "vite preview",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run --pass-with-no-tests",
    "test:unit:coverage": "vitest run --coverage",
    "test:unit:ui": "vitest --ui",
    "test:unit:watch": "vitest watch",
    "typecheck": "tsc --build --clean && tsc --build"
  },
  "dependencies": {
    "@tanstack/react-query": "5.101.1",
    "@tanstack/react-query-devtools": "5.101.1",
    "clsx": "2.1.1",
    "i18next": "26.3.2",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "6.1.2",
    "react-i18next": "17.0.8",
    "react-router": "8.0.1",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@commitlint/types": "21.1.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.1",
    "@tanstack/eslint-plugin-query": "5.101.1",
    "@tanstack/eslint-plugin-router": "1.162.0",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "autocorrect-node": "2.14.0",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "10.0.3",
    "cspell": "10.0.1",
    "eslint-plugin-i18next": "6.1.4",
    "html-validate": "11.5.3",
    "husky": "9.1.7",
    "i18next-cli": "1.64.2",
    "knip": "6.20.0",
    "lint-staged": "17.0.8",
    "markdownlint-cli": "0.49.0",
    "npm-check-updates": "22.2.7",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0",
    "stylelint": "17.14.0",
    "stylelint-config-css-modules": "4.6.0",
    "stylelint-config-recess-order": "7.7.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "5.2.0",
    "vite": "8.1.0",
    "vite-plugin-checker": "0.14.4",
    "vite-plugin-svgr": "5.2.0",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0 <25.0.0"
  },
  "packageManager": "pnpm@11.9.0"
}
